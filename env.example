# Supabase Configuration (Frontend - Vite)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Image optimization: set to true on Supabase Pro to serve resized/WebP images (faster load on Events & Home)
# VITE_SUPABASE_IMAGE_TRANSFORM=true

# Supabase Configuration (Backend - Server)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google reCAPTCHA Configuration
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Development: Disable reCAPTCHA for localhost (set to 'true' to bypass reCAPTCHA on localhost)
DISABLE_RECAPTCHA_LOCALHOST=true
VITE_DISABLE_RECAPTCHA_LOCALHOST=true

# Email SMTP Configuration
EMAIL_USER=support@andiamoevents.com
EMAIL_PASS=your_email_password_here
EMAIL_HOST=mail.routing.net
EMAIL_PORT=587

# Pending online expiry: GET/POST https://<your-domain>/api/auto-fail-pending-online-orders every few minutes (e.g. 5–15).
# Vercel Hobby allows crons at most once/day only — use an external scheduler (cron-job.org, etc.) or Vercel Pro + vercel.json crons.
# Protect with header x-cron-secret or ?secret= matching CRON_SECRET (set in Vercel env).
# CRON_SECRET=long-random-string
# PENDING_ONLINE_EXPIRE_MINUTES=17

# Server Configuration
PORT=8082
JWT_SECRET=your-secret-jwt-key-here

# ClicToPay (Click2Pay / SMT) Payment Gateway
# API credentials (used by backend). Console login is separate: https://portal.clictopay.com/epg_gui/#login
CLICTOPAY_API_USER=your_clictopay_api_user
CLICTOPAY_API_PASSWORD=your_clictopay_api_password
# Test: https://test.clictopay.com/payment/rest
# Prod:  https://ipay.clictopay.com/payment/rest  (register.do is appended by the app)
CLICTOPAY_BASE_URL=https://test.clictopay.com/payment/rest

# Public URL for payment callbacks (optional - defaults to Vercel URL or andiamoevents.com)
# VITE_PUBLIC_URL=https://andiamoevents.com

# WinSMS API Configuration (Optional - for SMS marketing features)
WINSMS_API_KEY=your_winsms_api_key_here
# TEST_PHONE=27169458  # Optional: Phone number for SMS testing (8 digits, starting with 2, 4, 5, or 9)

# Security Monitoring & Alerts
# SECURITY_ALERT_EMAIL=admin@example.com  # Email to receive security alerts (optional)
# ENABLE_SECURITY_LOGGING=true  # Enable comprehensive request logging (optional, defaults to production only)

# Meta Pixel (optional - for Meta Ads conversion/remarketing; leave unset to disable)
# VITE_META_PIXEL_ID=930929995973320
# Meta CAPI (optional - server-side Purchase dedup/support)
# META_CAPI_PIXEL_ID=930929995973320
# META_CAPI_ACCESS_TOKEN=your_meta_conversions_api_access_token_here

# Sentry (optional - leave unset to disable frontend error tracking; no console warning)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx