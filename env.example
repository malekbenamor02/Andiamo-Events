# Supabase Configuration (Frontend - Vite)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Image optimization: set to true on Supabase Pro to serve resized/WebP images (faster load on Events & Home)
# VITE_SUPABASE_IMAGE_TRANSFORM=true

# Supabase Configuration (Backend - Server)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google reCAPTCHA Configuration
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Development: Disable reCAPTCHA for localhost (set to 'true' to bypass reCAPTCHA on localhost)
DISABLE_RECAPTCHA_LOCALHOST=true
VITE_DISABLE_RECAPTCHA_LOCALHOST=true

# Admin login hardening (Vercel serverless)
# On VERCEL_ENV=production, RECAPTCHA_SECRET_KEY is required or admin login returns 503.
# Optional: distributed rate limits (same DB as Upstash Redis REST — create at https://console.upstash.com)
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here
# Optional tuning (defaults: 5 attempts per 15 minutes per IP and per email, in-memory + Upstash when configured)
# ADMIN_LOGIN_MAX_ATTEMPTS=5
# Minimum reCAPTCHA v3 score for admin login (0.0–1.0). Unset or invalid = 0.25 default when score is returned.
# ADMIN_RECAPTCHA_MIN_SCORE=0.25
# Set to 1 temporarily to include Google error codes / score in 400 JSON (remove in production after debugging).
# RECAPTCHA_RETURN_DIAGNOSTICS=1
# Optional: stop sending remoteip to Google siteverify (debug only if you suspect a bad client IP).
# RECAPTCHA_OMIT_REMOTEIP=1
# Require reCAPTCHA secret even outside Vercel production (e.g. staging you treat as locked down)
# FORCE_ADMIN_RECAPTCHA=1

# Email SMTP Configuration
EMAIL_USER=support@andiamoevents.com
EMAIL_PASS=your_email_password_here
EMAIL_HOST=mail.routing.net
EMAIL_PORT=587

# Brevo: Settings → SMTP & API → API keys. When set, transactional and marketing campaign emails use the REST API first (From on your verified domain, e.g. contact@andiamoevents.com).
# BREVO_API_KEY=xkeysib-your-key-here
# Optional: separate Brevo API key for investor / institutional template marketing sends (recommended).
# BREVO_API_KEY_INVESTORS=xkeysib-your-investor-key-here
# Investor From (verified in Brevo). If unset, sends use "Andiamo Events" <investors@andiamoevents.com> when template is institutional or sender profile is investor.
# MARKETING_INVESTOR_FROM="Andiamo Events Investors" <investors@andiamoevents.com>
# MARKETING_INVESTOR_REPLY_TO=contact@andiamoevents.com
# Optional deliverability override for investor outreach:
# by default investor sends suppress List-Unsubscribe headers and skip attachments.
# Set to 1 only if you intentionally want to allow attachments for investor sends.
# MARKETING_INVESTOR_ALLOW_ATTACHMENTS=0
# Optional: footer / signature URLs in investor institutional template
# INVESTOR_EMAIL_SOCIAL_INSTAGRAM=https://www.instagram.com/andiamo.events/
# INVESTOR_EMAIL_SOCIAL_LINKEDIN=https://www.linkedin.com/company/andiamoevents/
# INVESTOR_EMAIL_SOCIAL_WEB=https://www.andiamoevents.com/
# INVESTOR_EMAIL_SIGNATURE_IMAGE_URL=https://…/avatar.jpg
# Optional: footer “Developed by …” (defaults: Malek Ben Amor → https://malekbenamor.dev)
# INVESTOR_EMAIL_DEV_NAME=Malek Ben Amor
# INVESTOR_EMAIL_DEV_URL=https://malekbenamor.dev
# Optional: full https URL to override the black header logo (default: {site}/email-assets/logo-black.png)
# EMAIL_LOGO_BLACK_URL=https://www.andiamoevents.com/email-assets/logo-black.png
# Campaign / newsletter header logo (default: {site}/email-assets/logo-email.png)
# EMAIL_CAMPAIGN_LOGO_URL=https://www.andiamoevents.com/email-assets/logo-email.png
# Max bytes when the server fetches poster_attachment_url for attachments (default ~9 MB). Campaign editor uploads to storage and stores this URL automatically.
# MARKETING_ATTACHMENT_MAX_BYTES=9437184

# Pending online expiry: GET/POST https://<your-domain>/api/auto-fail-pending-online-orders every few minutes (e.g. 5–15).
# Vercel Hobby allows crons at most once/day only — use an external scheduler (cron-job.org, etc.) or Vercel Pro + vercel.json crons.
# Required for cron endpoints (min 16 chars). Use a long random string — never commit the real value.
# Send only via header x-cron-secret or Authorization: Bearer <CRON_SECRET> (do NOT use ?secret= in URLs).
# CRON_SECRET=replace-with-long-random-secret
# PENDING_ONLINE_EXPIRE_MINUTES=17

# Academy online (card) only — pending_payment / pending_online auto-cancelled after N minutes. RIB/D17 (proof_received) are never auto-expired.
# Cron (every 5–15 min): POST https://<your-domain>/api/auto-cancel-expired-academy-registrations
#   Header: x-cron-secret: <CRON_SECRET>  OR  Authorization: Bearer <CRON_SECRET>
# ACADEMY_PENDING_EXPIRE_MINUTES=17

# Email marketing cron: set CRON_SECRET on the server (same value as Supabase function secret). Schedule + MARKETING_CRON_URL are configured in Supabase only — see supabase/functions/marketing-email-tick/README.md. The URL is typically your production site; it must run the same api/misc.js version as the admin that creates drafts, or sends will ignore investor_template / investors@.
# Optional: set MARKETING_LOG_SEND=1 on the server to log each batch’s email_template and sender_profile (debugging only).
#
# --- ~3000 marketing emails in ~4 hours (Brevo Starter 5k/month) ---
# 1) BREVO_API_KEY on Vercel/production (Settings → SMTP & API → API keys).
# 2) Supabase Edge Function marketing-email-tick schedule: */2 * * * * (every 2 minutes).
# 3) Vercel env (optional if campaign UI sets batch 25 / delay 0 / cap 3500):
# MARKETING_CRON_BATCH_SIZE=25
# MARKETING_DEFAULT_DELAY_MINUTES_BETWEEN_EMAILS=0
# MARKETING_SEND_BATCH_MAX_MS=120000
# Must be ≤ (api/misc.js maxDuration in vercel.json − buffer). Default caps at ~55s on 60s functions.
# MARKETING_FUNCTION_MAX_DURATION_SEC=60
# MARKETING_SEND_DEADLINE_BUFFER_MS=5000
# Math: 120 ticks × 25 emails = 3000 in 4h with delay 0. With delay between emails, each cron tick sends fewer — use delay 0 or rely on cron spacing.
# 4) In admin campaign: Emails per day ≥ 3500, batch 25, delay 0.
# 5) Brevo: verify sending domain + sender; confirm monthly quota (5000) in Usage and plan.

# Server Configuration
PORT=8082
JWT_SECRET=your-secret-jwt-key-here

# ClicToPay (Click2Pay / SMT) Payment Gateway
# API credentials (used by backend). Console login is separate: https://portal.clictopay.com/epg_gui/#login
CLICTOPAY_API_USER=your_clictopay_api_user
CLICTOPAY_API_PASSWORD=your_clictopay_api_password
# Test: https://test.clictopay.com/payment/rest
# Prod:  https://ipay.clictopay.com/payment/rest  (register.do is appended by the app)
CLICTOPAY_BASE_URL=https://test.clictopay.com/payment/rest

# Public URL for payment callbacks (optional - defaults to Vercel URL or andiamoevents.com)
# VITE_PUBLIC_URL=https://andiamoevents.com

# WinSMS API Configuration (Optional - for SMS marketing features)
WINSMS_API_KEY=your_winsms_api_key_here
# TEST_PHONE=27169458  # Optional: Phone number for SMS testing (8 digits, starting with 2, 4, 5, or 9)

# Security Monitoring & Alerts
# SECURITY_ALERT_EMAIL=admin@example.com  # Email to receive security alerts (optional)
# ENABLE_SECURITY_LOGGING=true  # Enable comprehensive request logging (optional, defaults to production only)

# Meta Pixel (optional - for Meta Ads conversion/remarketing; leave unset to disable)
# VITE_META_PIXEL_ID=930929995973320
# Meta CAPI (optional - server-side Purchase dedup/support)
# META_CAPI_PIXEL_ID=930929995973320
# META_CAPI_ACCESS_TOKEN=your_meta_conversions_api_access_token_here

# Sentry (optional - leave unset to disable frontend error tracking; no console warning)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx